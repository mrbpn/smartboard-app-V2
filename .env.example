# ── Database (from Vercel → Storage → Neon) ──────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ── AI (optional — falls back gracefully if not set) ─────────
GEMINI_API_KEY=
VISION_API_KEY=

# ── Production (set in Vercel dashboard) ─────────────────────
# DATABASE_URL   → auto-injected by Vercel Neon integration
# JWT_SECRET     → add manually under Settings > Environment Variables
# GEMINI_API_KEY → add manually
